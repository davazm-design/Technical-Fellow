{
  "name": "@parallel-dev-kit/agentkit",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "CLI y validadores mecánicos del parallel-dev-kit (traducción ejecutable del CANON).",
  "bin": {
    "agentkit": "src/cli.ts"
  },
  "scripts": {
    "agentkit": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "generate:types": "tsx scripts/generate-types.ts",
    "validate:fixtures": "tsx scripts/validate-fixtures.ts",
    "selftest:ownership": "tsx scripts/selftest-ownership.ts",
    "ci": "npm run typecheck && npm test && npm run -s agentkit -- doctor && npm run validate:fixtures && npm run selftest:ownership && npm run -s agentkit -- eval"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "picomatch": "^4.0.4",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/picomatch": "^3.0.2",
    "json-schema-to-typescript": "^15.0.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
